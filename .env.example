# Copy to .env and fill in for Azure mode. Never commit the real .env file.
ENVIRONMENT=local
DATA_MODE=sample

DATABASE_URL=sqlite:///data/esg_platform.db

AZURE_STORAGE_CONNECTION_STRING=
AZURE_SQL_CONNECTION_STRING=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_KEY_VAULT_URL=

LOG_LEVEL=INFO
